<Window
    x:Class="BlinkReminder.Native.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    Title="眨眼提醒 Blink Reminder">

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="24"
            Padding="24"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="24">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock FontSize="34" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" Text="眨眼提醒" />
                    <TextBlock
                        MaxWidth="760"
                        TextWrapping="Wrap"
                        Foreground="{StaticResource SecondaryTextBrush}"
                        Text="这个原生重构版将使用 OpenVINO 多模型管线和 Windows ML，重点提升疲倦小眼、距离变化和单眼遮挡下的识别鲁棒性。" />
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="14,8"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="#173822"
                    CornerRadius="18">
                    <TextBlock Foreground="#B9F4C8" FontWeight="SemiBold" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24,0,24,16" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource CardTitleStyle}" Text="当前频率" />
                    <TextBlock Style="{StaticResource CardValueStyle}" Text="{x:Bind ViewModel.BlinksPerMinuteText, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource CardNoteStyle}" Text="次 / 分钟" />
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource CardTitleStyle}" Text="累计眨眼" />
                    <TextBlock Style="{StaticResource CardValueStyle}" Text="{x:Bind ViewModel.TotalBlinkCountText, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource CardNoteStyle}" Text="本次启动内统计" />
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource CardTitleStyle}" Text="最近一次眨眼" />
                    <TextBlock Style="{StaticResource CardValueStyle}" Text="{x:Bind ViewModel.LastBlinkText, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource CardNoteStyle}" Text="用于判断连续不眨眼时长" />
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource CardTitleStyle}" Text="当前策略" />
                    <TextBlock Style="{StaticResource CardValueStyle}" Text="{x:Bind ViewModel.PipelineModeText, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource CardNoteStyle}" Text="OpenVINO / Windows ML" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="24,0,24,24" ColumnSpacing="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="0.8*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="20" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="24">
                <StackPanel Spacing="14">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="重构目标" />
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}" Text="新管线不再依赖单一 FaceMesh + EAR，而是拆成独立的人脸检测、关键点定位、眼睛开闭分类和头姿过滤。这样能更稳地处理距离变化、自然小眼和单眼遮挡。" />
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="模型链路" />
                    <TextBlock Style="{StaticResource BulletStyle}" Text="1. face-detection-retail-0004：稳定做人脸检测" />
                    <TextBlock Style="{StaticResource BulletStyle}" Text="2. facial-landmarks-35-adas-0002：稳定提取眼部区域" />
                    <TextBlock Style="{StaticResource BulletStyle}" Text="3. open-closed-eye-0001：对左右眼分别做开闭分类" />
                    <TextBlock Style="{StaticResource BulletStyle}" Text="4. head-pose-estimation-adas-0001：过滤头部姿态极端情况" />
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="当前阶段" />
                    <TextBlock Style="{StaticResource BulletStyle}" Text="已完成原生工程骨架、模型目录约定和 Windows ML 启动入口" />
                    <TextBlock Style="{StaticResource BulletStyle}" Text="下一步在 Windows 开发机上接通相机采集与四模型推理链" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Padding="20" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="24">
                <StackPanel Spacing="14">
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="控制台" />
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource SecondaryTextBrush}" Text="{x:Bind ViewModel.DetailText, Mode=OneWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="开始原生管线" Command="{x:Bind ViewModel.StartCommand}" />
                        <Button Content="暂停" Command="{x:Bind ViewModel.PauseCommand}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="测试提醒" Command="{x:Bind ViewModel.TestReminderCommand}" />
                        <Button Content="打开模型目录" Command="{x:Bind ViewModel.OpenModelsFolderCommand}" />
                    </StackPanel>
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="近期事件" />
                    <controls:ItemsRepeater ItemsSource="{x:Bind ViewModel.RecentEvents, Mode=OneWay}">
                        <controls:ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border Margin="0,0,0,8" Padding="12" Background="#0A1320" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="14">
                                    <TextBlock Text="{x:Bind}" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                                </Border>
                            </DataTemplate>
                        </controls:ItemsRepeater.ItemTemplate>
                    </controls:ItemsRepeater>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
